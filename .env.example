# MySQL Database Configuration
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=chatbot_db

# Ollama Endpoint Configuration
# Use http://host.docker.internal:11434 to connect to Ollama running on your host machine (Windows/macOS GPU support)
# Use http://ollama:11434 if running Ollama as a Docker service
OLLAMA_HOST=http://host.docker.internal:11434

# Backend API Configuration
# Frontend uses this URL at build time to communicate with the FastAPI backend
VITE_API_URL=http://localhost:8000/api/v1

# Firebase Authentication Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# CORS configuration (Origins allowed to query the API)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:80,http://127.0.0.1:80
